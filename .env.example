# Zest environment variables
# Copy this file to .env.local and fill in your values.
# All VITE_ vars are bundled into the client build — never put secrets here.

# ---------------------------------------------------------------------------
# Firebase Firestore — shared project storage
# ---------------------------------------------------------------------------
# Create a project at https://console.firebase.google.com
# Enable Firestore Database (start in production mode).
# Add a web app to get these values from Project Settings > Your apps.
#
# Firestore security rule (paste in Firebase console):
#   rules_version = '2';
#   service cloud.firestore {
#     match /databases/{database}/documents {
#       match /shares/{shareId} {
#         allow read: if true;
#         allow write: if true;   // tighten this once you add auth
#       }
#     }
#   }
#
# When VITE_FIREBASE_PROJECT_ID is set the app uses Firestore for sharing.
# Leave it unset to fall back to localStorage (share links are device-local).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# ---------------------------------------------------------------------------
# Cloudinary — source image storage (WebP conversion)
# ---------------------------------------------------------------------------
# Create an account at https://cloudinary.com (free tier is generous).
# 1. Note your Cloud Name from the dashboard.
# 2. Go to Settings > Upload > Upload Presets > Add upload preset.
#    - Signing mode: Unsigned
#    - Folder: zest
#    - Format: webp
#    - Note the preset name.

VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
